# Frontend build / GitHub Actions
VITE_DEPLOYMENT_MODE=free
VITE_PUBLIC_APP_URL=https://packet-opt-control-tower.pages.dev
PUBLIC_APP_URL=https://packet-opt-control-tower.pages.dev
ALLOWED_ORIGINS=https://packet-opt-control-tower.pages.dev
PUBLIC_SECURITY_CONTACT=mailto:security@your-domain.com

# Optional only if you later switch to managed mode
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Cloudflare Pages runtime / .dev.vars - optional only for managed mode
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
RESEND_API_KEY=re_your_resend_api_key
